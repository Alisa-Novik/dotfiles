#!/usr/bin/env bash

set -euo pipefail

usage() {
  printf 'Usage: term-theme light|dark|toggle|status\n' >&2
  exit 2
}

resolve_script_path() {
  local target=$1 directory link
  while [[ -L "$target" ]]; do
    directory=$(CDPATH= cd -P -- "$(dirname -- "$target")" && pwd)
    link=$(readlink "$target")
    if [[ "$link" == /* ]]; then
      target=$link
    else
      target=$directory/$link
    fi
  done
  directory=$(CDPATH= cd -P -- "$(dirname -- "$target")" && pwd)
  printf '%s/%s\n' "$directory" "$(basename -- "$target")"
}

script_path=$(resolve_script_path "$0")
package_root=$(CDPATH= cd -- "$(dirname -- "$script_path")/../.." && pwd)
xdg_config_home=${XDG_CONFIG_HOME:-$HOME/.config}
kitty_config_dir=${KITTY_CONFIG_DIRECTORY:-$xdg_config_home/kitty}
kitty_theme_dir=$kitty_config_dir/themes
tmux_theme_dir=$xdg_config_home/tmux/themes
repo_kitty_theme_dir=$package_root/.config/kitty/themes
repo_tmux_theme_dir=$package_root/.config/tmux/themes
state_dir=${XDG_STATE_HOME:-$HOME/.local/state}/term-theme
state_file=$state_dir/mode
lock_dir=$state_dir/lock

# A Stow-installed script resolves into stow/common/.local/bin. Prefer the
# public XDG paths produced by Stow; the package-root fallback also makes the
# script testable directly from a checkout before links are installed.
if [[ ! -r "$kitty_theme_dir/Term Day.conf" || ! -r "$kitty_theme_dir/Term Night.conf" ]]; then
  kitty_theme_dir=$repo_kitty_theme_dir
fi
if [[ ! -r "$tmux_theme_dir/light.conf" || ! -r "$tmux_theme_dir/dark.conf" ]]; then
  tmux_theme_dir=$repo_tmux_theme_dir
fi

current_mode() {
  local saved=''
  if [[ -r "$state_file" ]]; then
    IFS= read -r saved < "$state_file" || true
  fi
  case "$saved" in
    light|dark) printf '%s\n' "$saved" ;;
    *)
      if cmp -s "$kitty_config_dir/current-theme.conf" "$kitty_theme_dir/Term Day.conf"; then
        printf 'light\n'
      else
        printf 'dark\n'
      fi
      ;;
  esac
}

kitty_sockets() {
  local pid command_line
  if [[ -n "${KITTY_LISTEN_ON:-}" ]]; then
    printf '%s\n' "$KITTY_LISTEN_ON"
  fi
  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    command_line=$(ps -ww -p "$pid" -o args= 2>/dev/null || true)
    sed -nE 's/.*--listen-on(=|[[:space:]]+)(unix:[^[:space:]]+).*/\2/p' <<< "$command_line"
  done < <(pgrep -x kitty 2>/dev/null || true)
}

reload_kitty() {
  local mode=$1 theme_file=$2 pid socket
  local current_theme=$kitty_config_dir/current-theme.conf
  local temporary_theme

  mkdir -p "$kitty_config_dir"
  if ! cmp -s "$theme_file" "$current_theme"; then
    temporary_theme=$(mktemp "$kitty_config_dir/.current-theme.conf.XXXXXX")
    cp "$theme_file" "$temporary_theme"
    chmod 0644 "$temporary_theme"
    mv -f "$temporary_theme" "$current_theme"
  fi

  while IFS= read -r pid; do
    [[ -n "$pid" ]] && kill -USR1 "$pid" 2>/dev/null || true
  done < <(pgrep -x kitty 2>/dev/null || true)

  sleep 0.2
  while IFS= read -r socket; do
    [[ -n "$socket" ]] || continue
    if [[ "$mode" == light ]]; then
      kitty @ --to "$socket" set-colors --all --configured "$theme_file" >/dev/null 2>&1 || true
    else
      kitty @ --to "$socket" set-colors --reset >/dev/null 2>&1 || true
    fi
  done < <(kitty_sockets | awk 'NF && !seen[$0]++')
}

reload_tmux() {
  local theme_file=$1 client
  if ! tmux list-sessions >/dev/null 2>&1; then
    return
  fi
  tmux source-file -n "$theme_file" >/dev/null
  tmux source-file "$theme_file"
  while IFS= read -r client; do
    [[ -n "$client" ]] && tmux refresh-client -t "$client"
  done < <(tmux list-clients -F '#{client_name}')
}

write_state() {
  local mode=$1 temporary_state
  mkdir -p "$state_dir"
  temporary_state=$(mktemp "$state_dir/.mode.XXXXXX")
  printf '%s\n' "$mode" > "$temporary_state"
  chmod 0600 "$temporary_state"
  mv -f "$temporary_state" "$state_file"
}

apply_mode() {
  local mode=$1 scope=${2:-all}
  local kitty_theme tmux_theme
  case "$mode" in
    light)
      kitty_theme=$kitty_theme_dir/Term\ Day.conf
      tmux_theme=$tmux_theme_dir/light.conf
      ;;
    dark)
      kitty_theme=$kitty_theme_dir/Term\ Night.conf
      tmux_theme=$tmux_theme_dir/dark.conf
      ;;
    *) usage ;;
  esac

  [[ -r "$kitty_theme" && -r "$tmux_theme" ]] || {
    printf 'term-theme: theme files are missing (kitty: %s, tmux: %s)\n' \
      "$kitty_theme_dir" "$tmux_theme_dir" >&2
    exit 1
  }

  mkdir -p "$state_dir"
  if ! mkdir "$lock_dir" 2>/dev/null; then
    printf 'term-theme: another switch is already running\n' >&2
    exit 1
  fi
  trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT

  if [[ "$scope" == tmux ]]; then
    reload_tmux "$tmux_theme"
  else
    reload_kitty "$mode" "$kitty_theme"
    reload_tmux "$tmux_theme"
    write_state "$mode"
  fi
  printf '%s\n' "$mode"
}

command=${1:-status}
case "$command" in
  light|dark) apply_mode "$command" ;;
  toggle)
    if [[ $(current_mode) == light ]]; then
      apply_mode dark
    else
      apply_mode light
    fi
    ;;
  status)
    mode=$(current_mode)
    printf 'mode=%s\n' "$mode"
    if tmux list-sessions >/dev/null 2>&1; then
      printf 'tmux=%s\n' "$(tmux show-options -gv status-style)"
    fi
    ;;
  --tmux-only)
    [[ $# -eq 2 ]] || usage
    apply_mode "$2" tmux
    ;;
  *) usage ;;
esac
