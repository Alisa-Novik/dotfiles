exec --no-startup-id xset -dpms
# Set modifier key and font
set $mod Mod1
font pango:monospace 8

gaps outer 2
gaps inner 2
smart_gaps on

new_window pixel 1
new_float pixel 1
client.focused #81A1C1 #81A1C1 #FFFFFF #81A1C1
client.unfocused #4C566A #4C566A #D8DEE9 #4C566A
client.focused_inactive #434C5E #434C5E #D8DEE9 #434C5E
client.urgent #BF616A #BF616A #FFFFFF #BF616A

# Start essential services
exec --no-startup-id dex --autostart --environment k/i3
#exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id setxkbmap -layout us,ru -option grp:ctrl_space_toggle

# Temporarily disabled after repeated desktop stalls on 2026-06-29.
# Run manually when needed: /home/alice/bin/cento display-layout-fix
# exec_always --no-startup-id /home/alice/bin/cento display-layout-fix
exec_always --no-startup-id xset r rate 220 30
exec_always --no-startup-id xset s off; xset s noblank; xset -dpms
exec_always --no-startup-id /home/alice/.config/cento/industrial-os/polybar/launch.sh
exec_always --no-startup-id ~/discord_updater.sh
exec_always --no-startup-id /home/alice/bin/cento wallpaper-manager --apply-current

exec_always --no-startup-id picom --config ~/.config/picom/picom.conf

# Audio controls
set $refresh_i3status1killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status
# Bluetooth AVRCP headsets and media keyboards
bindsym XF86AudioPlay exec --no-startup-id playerctl --player=playerctld play-pause
bindsym XF86AudioPause exec --no-startup-id playerctl --player=playerctld pause
bindsym XF86AudioNext exec --no-startup-id playerctl --player=playerctld next
bindsym XF86AudioPrev exec --no-startup-id playerctl --player=playerctld previous
bindsym XF86AudioStop exec --no-startup-id playerctl --player=playerctld stop
bindsym $mod+F11 exec --no-startup-id ~/.dotfiles/open-pavucontrol.sh

# Floating modifier
floating_modifier $mod
bindsym $mod+f fullscreen toggle

# Keep file browsers and GTK file dialogs from taking over the top monitor.
for_window [class="(?i)^(nautilus|org.gnome.Nautilus)$"] floating enable, resize set 1400 px 900 px, move position center
for_window [class="^Xdg-desktop-portal-gtk$"] floating enable, resize set 1400 px 900 px, move position center

# Launch terminal
bindsym $mod+Return exec kitty

# Kill focused window
bindsym $mod+c kill
# Physical P key; keeps Alt+P working when the active layout is Russian.
bindcode --release $mod+33 exec --no-startup-id flameshot gui

# Application launcher
bindsym $mod+space exec --no-startup-id ~/.config/polybar/scripts/launcher.sh
bindcode $mod+space exec "rofi -modi drun,run -show drun"

# Workspace definitions
set $ws1 1
set $ws2 2
set $ws3 3
set $ws4 4
set $ws5 5
set $ws6 6
set $ws7 7
set $ws8 8
set $wsl1 L2
set $wsl2 R2
set $wsr1 L1
set $wsr2 R1

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+h exec --no-startup-id /home/alice/projects/cento/scripts/industrial_focus.py left
bindsym $mod+j exec --no-startup-id /home/alice/projects/cento/scripts/industrial_focus.py down
bindsym $mod+k exec --no-startup-id /home/alice/projects/cento/scripts/industrial_focus.py up
bindsym $mod+l exec --no-startup-id /home/alice/projects/cento/scripts/industrial_focus.py right

# Assign workspaces to specific displays
workspace $ws1 output DP-4.8 DP-0.8
workspace $ws2 output DP-4.8 DP-0.8
workspace $ws3 output DP-4.8 DP-0.8
workspace $ws4 output DP-4.8 DP-0.8
workspace $ws5 output DP-4.8 DP-0.8
workspace $ws6 output DP-4.8 DP-0.8
workspace $ws7 output DP-4.8 DP-0.8
workspace $ws8 output DP-4.8 DP-0.8

workspace $wsl1 output HDMI-0
workspace $wsl2 output HDMI-0
workspace $wsr1 output HDMI-0
workspace $wsr2 output HDMI-0
# workspace $ws1 output HDMI-0
# workspace $ws2 output HDMI-0
# workspace $ws3 output HDMI-0
# workspace $ws4 output HDMI-0
# workspace $ws5 output HDMI-0
# workspace $ws6 output HDMI-0
# workspace $ws7 output HDMI-0
# workspace $ws8 output HDMI-0
#
# workspace $wsl1 output DP-0.8
# workspace $wsl2 output DP-0.8
# workspace $wsr1 output DP-0.8
# workspace $wsr2 output DP-0.8

# Bind keys to switch workspaces
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+a workspace $wsl1
bindsym $mod+d workspace $wsl2
bindsym $mod+q workspace $wsr1
bindsym $mod+e workspace $wsr2

# Bind keys to move focused container to a workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+a move container to workspace $wsl1
bindsym $mod+Shift+d move container to workspace $wsl2
bindsym $mod+Shift+q move container to workspace $wsr1
bindsym $mod+Shift+e move container to workspace $wsr2

# Reload or restart i3
bindsym $mod+Shift+g reload
bindsym $mod+Shift+r restart

# Autostart
# Keep PulseAudio repair on startup aligned with systemd user service recovery.
exec --no-startup-id /home/alice/.local/bin/pulseaudio-autofix
# exec_always bash /home/alice/.dotfiles/kbfix.sh

exec_always bash /home/alice/.dotfiles/kbfix.sh 
mode "resize" {
    # Resize with hjkl or arrow keys
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym l resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    # Exit resize mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

# i3bar disabled; Polybar is launched above.

